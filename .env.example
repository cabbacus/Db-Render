SECRET_KEY=change-this-to-a-random-string
APP_USERNAME=admin
APP_PASSWORD=choose-a-real-password
# Recommended: a Postgres or MongoDB URL to persist your watched-database list across restarts.
# Without this, the list is stored in local SQLite and can reset on Render's free tier.
METADATA_DATABASE_URL=
# Optional: lets external monitors call /api/health?key=... without logging in
HEALTH_API_KEY=
